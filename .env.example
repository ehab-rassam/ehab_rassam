# =============================================================================
# FRONTEND (Vite) — only variables prefixed with VITE_ are embedded in the bundle.
# Never put TELEGRAM_BOT_TOKEN, TELEGRAM_CHAT_ID, or other secrets in VITE_* vars.
# =============================================================================

# Public contact API URL (no secrets).
# Dev: same-origin path so the browser hits Vite, which proxies to the relay (vite.config.js).
# Do not point the SPA at http://127.0.0.1:5175 in dev (CORS + you want the Vite proxy).
# Production: full HTTPS URL of your deployed relay (Cloudflare Worker, VPS, etc.).
VITE_CONTACT_API_URL=/api/contact

# Optional: if the relay listens elsewhere, set the proxy target (Vite dev + preview only).
# CONTACT_API_PROXY_TARGET=http://127.0.0.1:5175

# =============================================================================
# SERVER RELAY (server/telegram-proxy.mjs) — never prefix these with VITE_
# =============================================================================

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Comma-separated exact origins (scheme + host + port). Required in production.
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CONTACT_API_PORT=5175

# Relay logging: NODE_ENV=production or CONTACT_API_QUIET=1 → minimal logs.
# CONTACT_API_DEBUG=1 → verbose Telegram request/response logging (dev/troubleshooting).

# For `npm run preview` with the contact form: run `npm run dev:contact-api` in another terminal
# (same relay + CONTACT_API_PROXY_TARGET / default 127.0.0.1:5175), then open the preview URL.
